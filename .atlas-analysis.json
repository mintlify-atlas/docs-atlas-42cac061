  "keyFeatures": [
    "Scrape jobs from 9 major job boards simultaneously",
    "Browser TLS fingerprint emulation with wreq-js",
    "Optional credential-based authentication for blocked sites",
    "Profile-based deduplication across runs",
    "Proxy rotation and country-specific domains",
    "Three interfaces: SDK, CLI, and MCP server",
    "Automatic salary extraction from descriptions",
    "Support for 60+ countries"
  ],
  "publicApiSurface": [
    "scrapeJobs(params: ScrapeJobsParams): Promise<JobResponse>",
    "fetchLinkedInJob(jobId: string, options?): Promise<LinkedInJobDetails>",
    "fetchJobDetails(site: string, jobId: string, options?): Promise<JobPost>",
    "Site enum (LINKEDIN, INDEED, GLASSDOOR, GOOGLE, etc.)",
    "JobType enum (FULL_TIME, PART_TIME, CONTRACT, etc.)",
    "CompensationInterval enum (YEARLY, MONTHLY, HOURLY, etc.)",
    "DescriptionFormat enum (MARKDOWN, HTML, PLAIN)",
    "JobPost interface",
    "JobResponse interface",
    "ScrapeJobsParams interface",
    "ProviderCredentials interface"
  ]
