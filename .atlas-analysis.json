  "projectType": "sdk-library",
  "projectName": "JobSpy JS",
  "projectDescription": "TypeScript job scraper for LinkedIn, Indeed, Glassdoor, Google, ZipRecruiter, Bayt, Naukri & BDJobs",
  "theme": "palm",
